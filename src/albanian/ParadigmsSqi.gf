  oper mkV3 = overload {
                mkV3 : {indicative : Tense => Number => Person => Str;
                        imperative : Number => Str; participle : Str;
                        pres_optative : Number => Person => Str;
                        perf_optative : Number => Person => Str;
                        pres_admirative : Number => Person => Str;
                        imperf_admirative : Number => Person => Str;
                        lock_V : {}} -> {indicative : Tense => Number => Person => Str;
                                         imperative : Number => Str; participle : Str;
                                         pres_optative : Number => Person => Str;
                                         perf_optative : Number => Person => Str;
                                         pres_admirative : Number => Person => Str;
                                         imperf_admirative : Number => Person => Str;
                                         c2 : {s : Str}; c3 : {s : Str}; lock_V3 : {}}
                     = \v -> {indicative : Tense => Number => Person => Str
                                         = v.indicative;
                              imperative : Number => Str = v.imperative;
