resource ParadigmsSqi = MorphoSqi ** open Predef,Prelude,CatSqi,ResSqi in {
  flags
    coding = "UTF-8" ;
  oper mkA = overload {
               mkA : Str -> {s : Case => Gender => Number => Str; clit : Bool;
                             lock_A : {}}
                   = regA ;
               mkA : Str -> Str -> {s : Case => Gender => Number => Str;
                                    clit : Bool; lock_A : {}}
                   = reg2A ;
             } ;
  oper mkA2 = overload {
                mkA2 : {s : Case => Gender => Number => Str; clit : Bool;
                        lock_A : {}} -> {s : Case => Gender => Number => Str; clit : Bool;
                                         c2 : {s : Str}; lock_A2 : {}}
                     = \a -> {s : Case => Gender => Number => Str = a.s;
                              clit : Bool = a.clit; c2 : {s : Str} = noPrep; lock_A2 : {} = <>} ;
                mkA2 : {s : Case => Gender => Number => Str; clit : Bool;
                        lock_A : {}} -> {s : Str;
                                         lock_Prep : {}} -> {s : Case => Gender => Number => Str;
                                                             clit : Bool; c2 : {s : Str};
                                                             lock_A2 : {}}
                     = \a,p -> {s : Case => Gender => Number => Str = a.s;
                                clit : Bool = a.clit; c2 : {s : Str} = p; lock_A2 : {} = <>} ;
              } ;
  oper mkACard : Str -> {s : Str; lock_ACard : {}}
               = \s -> {s : Str = s; lock_ACard : {} = <>} ;
  oper mkAdA : Str -> {s : Str; lock_AdA : {}}
             = \s -> {s : Str = s; lock_AdA : {} = <>} ;
  oper mkAdN : Str -> {s : Str; lock_AdN : {}}
             = \s -> {s : Str = s; lock_AdN : {} = <>} ;
  oper mkAdV : Str -> {s : Str; lock_AdV : {}}
             = \s -> {s : Str = s; lock_AdV : {} = <>} ;
  oper mkAdv : Str -> {s : Str; lock_Adv : {}}
             = \s -> {s : Str = s; lock_Adv : {} = <>} ;
  oper mkCAdv : Str -> {s : Str; p : Str; lock_CAdv : {}}
              = \s -> {s : Str = s; p : Str = []; lock_CAdv : {} = <>} ;
  oper mkCard : Str -> {s : Str; lock_Card : {}}
              = \s -> {s : Str = s; lock_Card : {} = <>} ;
  oper mkConj : Str -> {s : Str; lock_Conj : {}}
              = \s -> {s : Str = s; lock_Conj : {} = <>} ;
  oper mkDet : Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Number -> {s : Case => Gender => Str;
                                                                                  sp : Species;
                                                                                  n : Number;
                                                                                  lock_Det : {}}
             = \f1,f2,f3,f4,f5,f6,f7,f8,n -> {s : Case => Gender => Str
                                                = table Case {
                                                    Nom => table Gender {
                                                             Masc => f1;
                                                             Fem => f2
                                                           };
                                                    Acc => table Gender {
                                                             Masc => f3;
                                                             Fem => f4
                                                           };
                                                    Dat => table Gender {
                                                             Masc => f5;
                                                             Fem => f6
                                                           };
                                                    Ablat => table Gender {
                                                               Masc => f7;
                                                               Fem => f8
                                                             }
                                                  };
                                              sp : Species = Indef; n : Number = n;
                                              lock_Det : {} = <>} ;
  oper mkGN : Str -> {s : Str; lock_GN : {}}
            = \s -> {s : Str = s; lock_GN : {} = <>} ;
  oper mkIAdv : Str -> {s : Str; lock_IAdv : {}}
              = \s -> {s : Str = s; lock_IAdv : {} = <>} ;
  oper mkIDet : Str -> {s : Str; lock_IDet : {}}
              = \s -> {s : Str = s; lock_IDet : {} = <>} ;
  oper mkIP : Str -> {s : Str; lock_IP : {}}
            = \s -> {s : Str = s; lock_IP : {} = <>} ;
  oper mkIQuant : Str -> {s : Str; lock_IQuant : {}}
                = \s -> {s : Str = s; lock_IQuant : {} = <>} ;
  oper mkInterj : Str -> {s : Str; lock_Interj : {}}
                = \s -> {s : Str = s; lock_Interj : {} = <>} ;
  oper mkLN : Str -> {s : Str; lock_LN : {}}
            = \s -> {s : Str = s; lock_LN : {} = <>} ;
  oper mkMU : Str -> {s : Str; isPre : Bool; lock_MU : {}}
            = \s -> {s : Str = s; isPre : Bool = False; lock_MU : {} = <>} ;
  oper mkN = overload {
               mkN : Str -> {s : Species => Case => Number => Str; g : Gender;
                             lock_N : {}}
                   = regN ;
               mkN : Str -> Str -> {s : Species => Case => Number => Str;
                                    g : Gender; lock_N : {}}
                   = reg2N ;
             } ;
  oper mkN2 = overload {
                mkN2 : {s : Species => Case => Number => Str; g : Gender;
                        lock_N : {}} -> {s : Species => Case => Number => Str; g : Gender;
                                         c2 : {s : Str}; lock_N2 : {}}
                     = \n -> {s : Species => Case => Number => Str = n.s;
                              g : Gender = n.g; c2 : {s : Str} = noPrep; lock_N2 : {} = <>} ;
                mkN2 : {s : Species => Case => Number => Str; g : Gender;
                        lock_N : {}} -> {s : Str;
                                         lock_Prep : {}} -> {s : Species => Case => Number => Str;
                                                             g : Gender; c2 : {s : Str};
                                                             lock_N2 : {}}
                     = \n,p -> {s : Species => Case => Number => Str = n.s;
                                g : Gender = n.g; c2 : {s : Str} = p; lock_N2 : {} = <>} ;
              } ;
  oper mkPConj : Str -> {s : Str; lock_PConj : {}}
               = \s -> {s : Str = s; lock_PConj : {} = <>} ;
  oper mkPN : Str -> {s : Str; lock_PN : {}}
            = \s -> {s : Str = s; lock_PN : {} = <>} ;
  oper mkPredet : Str -> {s : Str; lock_Predet : {}}
                = \s -> {s : Str = s; lock_Predet : {} = <>} ;
  oper mkPrep : Str -> {s : Str; lock_Prep : {}}
              = \s -> {s : Str = s; lock_Prep : {} = <>} ;
  oper mkPron : (nom : Str) -> (acc : Str) -> (dat : Str) -> (ablat : Str) -> (acc_clit : Str) -> (dat_clit : Str) -> GenNum -> Person -> {s : Case => Str;
                                                                                                                                           acc_clit : Str;
                                                                                                                                           dat_clit : Str;
                                                                                                                                           a : {gn : GenNum;
                                                                                                                                                p : Person};
                                                                                                                                           lock_Pron : {}}
              = \nom,acc,dat,ablat,acc_clit,dat_clit,gn,p -> {s : Case => Str
                                                                = table Case [nom; acc; dat; ablat];
                                                              acc_clit : Str = acc_clit;
                                                              dat_clit : Str = dat_clit;
                                                              a : {gn : GenNum; p : Person}
                                                                = {gn : GenNum = gn;
                                                                   p : Person = p};
                                                              lock_Pron : {} = <>} ;
  oper mkQuant : Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> Str -> {s : Case => Gender => Number => Str;
                                                                                                                                  sp : Species;
                                                                                                                                  lock_Quant : {}}
               = \f1,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,f12,f13,f14,f15,f16 -> {s : Case => Gender => Number => Str
                                                                               = table Case {
                                                                                   Nom => table Gender {
                                                                                            Masc => table Number {
                                                                                                      Sg => f1;
                                                                                                      Pl => f2
                                                                                                    };
                                                                                            Fem => table Number {
                                                                                                     Sg => f3;
                                                                                                     Pl => f4
                                                                                                   }
                                                                                          };
                                                                                   Acc => table Gender {
                                                                                            Masc => table Number {
                                                                                                      Sg => f5;
                                                                                                      Pl => f6
                                                                                                    };
                                                                                            Fem => table Number {
                                                                                                     Sg => f7;
                                                                                                     Pl => f8
                                                                                                   }
                                                                                          };
                                                                                   Dat => table Gender {
                                                                                            Masc => table Number {
                                                                                                      Sg => f9;
                                                                                                      Pl => f10
                                                                                                    };
                                                                                            Fem => table Number {
                                                                                                     Sg => f11;
                                                                                                     Pl => f12
                                                                                                   }
                                                                                          };
                                                                                   Ablat => table Gender {
                                                                                              Masc => table Number {
                                                                                                        Sg => f13;
                                                                                                        Pl => f14
                                                                                                      };
                                                                                              Fem => table Number {
                                                                                                       Sg => f15;
                                                                                                       Pl => f16
                                                                                                     }
                                                                                            }
                                                                                 };
                                                                             sp : Species = Indef;
                                                                             lock_Quant : {} = <>} ;
  oper mkSN : Str -> {s : Str; lock_SN : {}}
            = \s -> {s : Str = s; lock_SN : {} = <>} ;
  oper mkSubj : Str -> {s : Str; lock_Subj : {}}
              = \s -> {s : Str = s; lock_Subj : {} = <>} ;
  oper mkV = overload {
               mkV : Str -> {indicative : Tense => Number => Person => Str;
                             imperative : Number => Str; participle : Str;
                             pres_optative : Number => Person => Str;
                             perf_optative : Number => Person => Str;
                             pres_admirative : Number => Person => Str;
                             imperf_admirative : Number => Person => Str; lock_V : {}}
                   = regV ;
               mkV : Str -> Str -> {indicative : Tense => Number => Person => Str;
                                    imperative : Number => Str; participle : Str;
                                    pres_optative : Number => Person => Str;
                                    perf_optative : Number => Person => Str;
                                    pres_admirative : Number => Person => Str;
                                    imperf_admirative : Number => Person => Str; lock_V : {}}
                   = reg2V ;
             } ;
  oper mkV2 = overload {
                mkV2 : {indicative : Tense => Number => Person => Str;
                        imperative : Number => Str; participle : Str;
                        pres_optative : Number => Person => Str;
                        perf_optative : Number => Person => Str;
                        pres_admirative : Number => Person => Str;
                        imperf_admirative : Number => Person => Str;
                        lock_V : {}} -> {indicative : Tense => Number => Person => Str;
                                         imperative : Number => Str; participle : Str;
                                         pres_optative : Number => Person => Str;
                                         perf_optative : Number => Person => Str;
                                         pres_admirative : Number => Person => Str;
                                         imperf_admirative : Number => Person => Str;
                                         c2 : {s : Str}; lock_V2 : {}}
                     = \v -> {indicative : Tense => Number => Person => Str
                                         = v.indicative;
                              imperative : Number => Str = v.imperative;
                              participle : Str = v.participle;
                              pres_optative : Number => Person => Str = v.pres_optative;
                              perf_optative : Number => Person => Str = v.perf_optative;
                              pres_admirative : Number => Person => Str = v.pres_admirative;
                              imperf_admirative : Number => Person => Str = v.imperf_admirative;
                              c2 : {s : Str} = noPrep; lock_V2 : {} = <>} ;
                mkV2 : {indicative : Tense => Number => Person => Str;
                        imperative : Number => Str; participle : Str;
                        pres_optative : Number => Person => Str;
                        perf_optative : Number => Person => Str;
                        pres_admirative : Number => Person => Str;
                        imperf_admirative : Number => Person => Str;
                        lock_V : {}} -> {s : Str;
                                         lock_Prep : {}} -> {indicative : Tense => Number => Person => Str;
                                                             imperative : Number => Str;
                                                             participle : Str;
                                                             pres_optative : Number => Person => Str;
                                                             perf_optative : Number => Person => Str;
                                                             pres_admirative : Number => Person => Str;
                                                             imperf_admirative : Number => Person => Str;
                                                             c2 : {s : Str}; lock_V2 : {}}
                     = \v,p -> {indicative : Tense => Number => Person => Str
                                           = v.indicative;
                                imperative : Number => Str = v.imperative;
                                participle : Str = v.participle;
                                pres_optative : Number => Person => Str = v.pres_optative;
                                perf_optative : Number => Person => Str = v.perf_optative;
                                pres_admirative : Number => Person => Str = v.pres_admirative;
                                imperf_admirative : Number => Person => Str = v.imperf_admirative;
                                c2 : {s : Str} = p; lock_V2 : {} = <>} ;
              } ;
  oper mkV2A = overload {
                 mkV2A : {indicative : Tense => Number => Person => Str;
                          imperative : Number => Str; participle : Str;
                          pres_optative : Number => Person => Str;
                          perf_optative : Number => Person => Str;
                          pres_admirative : Number => Person => Str;
                          imperf_admirative : Number => Person => Str;
                          lock_V : {}} -> {indicative : Tense => Number => Person => Str;
                                           imperative : Number => Str; participle : Str;
                                           pres_optative : Number => Person => Str;
                                           perf_optative : Number => Person => Str;
                                           pres_admirative : Number => Person => Str;
                                           imperf_admirative : Number => Person => Str;
                                           c2 : {s : Str}; c3 : {s : Str}; lock_V2A : {}}
                       = \v -> {indicative : Tense => Number => Person => Str
                                           = v.indicative;
                                imperative : Number => Str = v.imperative;
                                participle : Str = v.participle;
                                pres_optative : Number => Person => Str = v.pres_optative;
                                perf_optative : Number => Person => Str = v.perf_optative;
                                pres_admirative : Number => Person => Str = v.pres_admirative;
                                imperf_admirative : Number => Person => Str = v.imperf_admirative;
                                c2 : {s : Str} = noPrep; c3 : {s : Str} = noPrep;
                                lock_V2A : {} = <>} ;
                 mkV2A : {indicative : Tense => Number => Person => Str;
                          imperative : Number => Str; participle : Str;
                          pres_optative : Number => Person => Str;
                          perf_optative : Number => Person => Str;
                          pres_admirative : Number => Person => Str;
                          imperf_admirative : Number => Person => Str;
                          lock_V : {}} -> {s : Str; lock_Prep : {}} -> {s : Str;
                                                                        lock_Prep : {}} -> {indicative : Tense => Number => Person => Str;
                                                                                            imperative : Number => Str;
                                                                                            participle : Str;
                                                                                            pres_optative : Number => Person => Str;
                                                                                            perf_optative : Number => Person => Str;
                                                                                            pres_admirative : Number => Person => Str;
                                                                                            imperf_admirative : Number => Person => Str;
                                                                                            c2 : {s : Str};
                                                                                            c3 : {s : Str};
                                                                                            lock_V2A : {}}
                       = \v,p2,p3 -> {indicative : Tense => Number => Person => Str
                                                 = v.indicative;
                                      imperative : Number => Str = v.imperative;
                                      participle : Str = v.participle;
                                      pres_optative : Number => Person => Str = v.pres_optative;
                                      perf_optative : Number => Person => Str = v.perf_optative;
                                      pres_admirative : Number => Person => Str = v.pres_admirative;
                                      imperf_admirative : Number => Person => Str
                                                        = v.imperf_admirative;
                                      c2 : {s : Str} = p2; c3 : {s : Str} = p3;
                                      lock_V2A : {} = <>} ;
               } ;
  oper mkV2Q = overload {
                 mkV2Q : {indicative : Tense => Number => Person => Str;
                          imperative : Number => Str; participle : Str;
                          pres_optative : Number => Person => Str;
                          perf_optative : Number => Person => Str;
                          pres_admirative : Number => Person => Str;
                          imperf_admirative : Number => Person => Str;
                          lock_V : {}} -> {indicative : Tense => Number => Person => Str;
                                           imperative : Number => Str; participle : Str;
                                           pres_optative : Number => Person => Str;
                                           perf_optative : Number => Person => Str;
                                           pres_admirative : Number => Person => Str;
                                           imperf_admirative : Number => Person => Str;
                                           c2 : {s : Str}; lock_V2Q : {}}
                       = \v -> {indicative : Tense => Number => Person => Str
                                           = v.indicative;
                                imperative : Number => Str = v.imperative;
                                participle : Str = v.participle;
                                pres_optative : Number => Person => Str = v.pres_optative;
                                perf_optative : Number => Person => Str = v.perf_optative;
                                pres_admirative : Number => Person => Str = v.pres_admirative;
                                imperf_admirative : Number => Person => Str = v.imperf_admirative;
                                c2 : {s : Str} = noPrep; lock_V2Q : {} = <>} ;
                 mkV2Q : {indicative : Tense => Number => Person => Str;
                          imperative : Number => Str; participle : Str;
                          pres_optative : Number => Person => Str;
                          perf_optative : Number => Person => Str;
                          pres_admirative : Number => Person => Str;
                          imperf_admirative : Number => Person => Str;
                          lock_V : {}} -> {s : Str; lock_Prep : {}} -> {s : Str;
                                                                        lock_Prep : {}} -> {indicative : Tense => Number => Person => Str;
                                                                                            imperative : Number => Str;
                                                                                            participle : Str;
                                                                                            pres_optative : Number => Person => Str;
                                                                                            perf_optative : Number => Person => Str;
                                                                                            pres_admirative : Number => Person => Str;
                                                                                            imperf_admirative : Number => Person => Str;
                                                                                            c2 : {s : Str};
                                                                                            lock_V2Q : {}}
                       = \v,p2,p3 -> {indicative : Tense => Number => Person => Str
                                                 = v.indicative;
                                      imperative : Number => Str = v.imperative;
                                      participle : Str = v.participle;
                                      pres_optative : Number => Person => Str = v.pres_optative;
                                      perf_optative : Number => Person => Str = v.perf_optative;
                                      pres_admirative : Number => Person => Str = v.pres_admirative;
                                      imperf_admirative : Number => Person => Str
                                                        = v.imperf_admirative;
                                      c2 : {s : Str} = p2; lock_V2Q : {} = <>} ;
               } ;
